local function switchTab(id)
    PlayClick()
    for tid, page in pairs(tabPages) do
        page.Visible = (tid == id)
    end
    for tid, btn in pairs(tabBtns) do
        local active = (tid == id)
        Tween(btn, fast, {
            BackgroundColor3 = active and C.ACCENT or C.BG3,
            TextColor3       = active and C.WHITE or C.TEXTSUB,
        })
    end
    activeTab = id
end

