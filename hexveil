-- AC Tab switch
local function switchACTab(t)
    PlayClick()
    soundPanel.Visible = t == "sound"; imagePanel.Visible = t == "image"
    Tween(acTabSound, fast, {BackgroundColor3 = t == "sound" and C.ACCENT or C.BG, TextColor3 = t == "sound" and C.WHITE or C.TEXTSUB})
    Tween(acTabImage, fast, {BackgroundColor3 = t == "image" and C.ACCENT or C.BG, TextColor3 = t == "image" and C.WHITE or C.TEXTSUB})
end

acTabSound.MouseButton1Click:Connect(function() switchACTab("sound") end)
