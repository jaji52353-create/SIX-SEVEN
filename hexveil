local function makeToggleRow(parent, labelText, yPos)
    local row = Instance.new("Frame", parent)
    row.Size              = UDim2.new(1, -20, 0, 40)
    row.Position          = UDim2.new(0, 10, 0, yPos)
    row.BackgroundColor3  = C.BG3
    row.BorderSizePixel   = 0
    row.ZIndex            = 12
    Instance.new("UICorner", row).CornerRadius = UDim.new(0, 8)

    local lbl = Instance.new("TextLabel", row)
    lbl.Size              = UDim2.new(1, -80, 1, 0)
    lbl.Position          = UDim2.new(0, 12, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text              = labelText
    lbl.TextColor3        = C.TEXT
    lbl.Font              = Enum.Font.GothamBold
    lbl.TextSize          = 13
    lbl.TextXAlignment    = Enum.TextXAlignment.Left
    lbl.ZIndex            = 13

    -- Status label
    local statusLbl = Instance.new("TextLabel", row)
    statusLbl.Size              = UDim2.new(0, 35, 1, 0)
    statusLbl.Position          = UDim2.new(1, -100, 0, 0)
    statusLbl.BackgroundTransparency = 1
    statusLbl.Text              = "OFF"
    statusLbl.TextColor3        = C.OFF
    statusLbl.Font              = Enum.Font.GothamBold
    statusLbl.TextSize          = 11
    statusLbl.ZIndex            = 13

    -- Switch track
    local track = Instance.new("Frame", row)
    track.Size              = UDim2.new(0, 46, 0, 24)
    track.Position          = UDim2.new(1, -58, 0.5, -12)
    track.BackgroundColor3  = C.OFF
    track.BorderSizePixel   = 0
    track.ZIndex            = 13
    Instance.new("UICorner", track).CornerRadius = UDim.new(1, 0)

    local knob = Instance.new("Frame", track)
    knob.Size              = UDim2.new(0, 20, 0, 20)
    knob.Position          = UDim2.new(0, 2, 0.5, -10)
    knob.BackgroundColor3  = C.WHITE
    knob.BorderSizePixel   = 0
    knob.ZIndex            = 14
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

    local clickBtn = Instance.new("TextButton", row)
    clickBtn.Size                 = UDim2.new(1, 0, 1, 0)
    clickBtn.BackgroundTransparency = 1
    clickBtn.Text                 = ""
    clickBtn.ZIndex               = 15

    local state = false
    local function setVisual(on)
        Tween(track, fast, {BackgroundColor3 = on and C.ACCENT or C.OFF})
        Tween(knob,  fast, {Position = on and UDim2.new(0, 24, 0.5, -10) or UDim2.new(0, 2, 0.5, -10)})
        statusLbl.Text      = on and "ON" or "OFF"
        statusLbl.TextColor3 = on and C.ON or C.OFF
    end

    -- hover effect
    clickBtn.MouseEnter:Connect(function()
        Tween(row, fast, {BackgroundColor3 = Color3.fromRGB(28, 28, 42)})
    end)
    clickBtn.MouseLeave:Connect(function()
        Tween(row, fast, {BackgroundColor3 = C.BG3})
    end)

    return clickBtn, setVisual, function() return state end, function(v) state = v end, row
end

