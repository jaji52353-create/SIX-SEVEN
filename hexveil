local aimbotSmoothness = 0.12

local function getNearestPlayer()
    local nearest, minDist = nil, math.huge
    local myChar = LocalPlayer.Character
    if not myChar then return nil end
    local myRoot = myChar:FindFirstChild("HumanoidRootPart")
    if not myRoot then return nil end

    local vpSize = Camera.ViewportSize
    local cx, cy = vpSize.X / 2, vpSize.Y / 2

    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            local char = p.Character
            if char then
                local head = char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
                local hum = char:FindFirstChildOfClass("Humanoid")
                if head and hum and hum.Health > 0 then
                    local screenPos, onScreen = Camera:WorldToScreenPoint(head.Position)
                    if onScreen then
                        local dx, dy = screenPos.X - cx, screenPos.Y - cy
                        local dist = math.sqrt(dx*dx + dy*dy)
                        if dist < minDist then
                            minDist = dist
                            nearest = p
                        end
                    end
                end
            end
        end
    end
    return nearest
end

local function startAimbot()
    if aimbotConnection then return end
    aimbotConnection = RunService.RenderStepped:Connect(function()
        if not state.aimbot then return end
        local delta = UserInputService:GetMouseDelta()
        if delta.Magnitude > 1.5 then return end

        local target = getNearestPlayer()
        if not target then return end
        local char = target.Character
        if not char then return end
        local head = char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
        if not head then return end

        local camPos = Camera.CFrame.Position
        local dir = (head.Position - camPos).Unit
        local goal = CFrame.lookAt(camPos, camPos + dir)
        Camera.CFrame = Camera.CFrame:Lerp(goal, aimbotSmoothness)
    end)
end

local function stopAimbot()
    if aimbotConnection then aimbotConnection:Disconnect(); aimbotConnection = nil end
end

