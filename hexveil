local function showToast(msg, color)
    color = color or C.ACCENT2
    local toast = Instance.new("Frame", ScreenGui)
    toast.Size = UDim2.new(0, 260, 0, 36); toast.Position = UDim2.new(0.5, -130, 0, -50)
    toast.BackgroundColor3 = C.BG2; toast.BorderSizePixel = 0; toast.ZIndex = 60
    Instance.new("UICorner", toast).CornerRadius = UDim.new(0, 8)
    local ts = Instance.new("UIStroke", toast); ts.Color = color; ts.Thickness = 1.5
    local tl = Instance.new("TextLabel", toast)
    tl.Size = UDim2.new(1,-16,1,0); tl.Position = UDim2.new(0,8,0,0)
    tl.BackgroundTransparency = 1; tl.Text = msg; tl.TextColor3 = color
    tl.Font = Enum.Font.GothamBold; tl.TextSize = 12; tl.ZIndex = 61
    Tween(toast, med, {Position = UDim2.new(0.5,-130,0,50)})
    task.delay(2.5, function()
        Tween(toast, fast, {Position = UDim2.new(0.5,-130,0,-50)})
        task.delay(0.2, function() if toast and toast.Parent then toast:Destroy() end end)
    end)
end

