local function parseID(input)
    local raw = input:match("^%s*(.-)%s*$")
    return raw:match("rbxassetid://(%d+)") or raw:match("^(%d+)$")
end

local function addHistoryRow(scroll, order, id, isWork, status)
    local row = Instance.new("Frame", scroll)
    row.Size = UDim2.new(1,0,0,24); row.BackgroundColor3 = isWork and Color3.fromRGB(10,28,14) or Color3.fromRGB(28,10,10)
    row.BorderSizePixel = 0; row.LayoutOrder = order; row.ZIndex = 15
    Instance.new("UICorner", row).CornerRadius = UDim.new(0,4)
    local lbl = Instance.new("TextLabel", row)
    lbl.Size = UDim2.new(1,-8,1,0); lbl.Position = UDim2.new(0,6,0,0)
    lbl.BackgroundTransparency = 1; lbl.RichText = true; lbl.TextWrapped = false
    lbl.Text = string.format('<font color="#888888">[%s]</font> <font color="#aaaaff">%s</font>  <font color="%s"><b>%s</b></font>',
        getTimeStr(), id, isWork and "#44ff88" or "#ff5555", status)
    lbl.TextColor3 = C.TEXT; lbl.TextSize = 9; lbl.Font = Enum.Font.Code
    lbl.TextXAlignment = Enum.TextXAlignment.Left; lbl.ZIndex = 16
    task.defer(function() scroll.CanvasPosition = Vector2.new(0, math.huge) end)
end

-- Sound logic
local function destroyCurrentSound()
    if currentSound then pcall(function() currentSound:Stop() end); pcall(function() currentSound:Destroy() end); currentSound = nil end
end

sndCheckBtn.MouseButton1Click:Connect(function()
    PlayClick()
    local id = parseID(soundInputBox.Text)
    if not id then sndStatusLbl.Text = '<font color="#ffaa00">ID tidak valid</font>'; return end
    sndStatusLbl.Text = '<font color="#aaaaff">Mengecek...</font>'
    task.spawn(function()
        local temp = Instance.new("Sound"); temp.SoundId = "rbxassetid://"..id; temp.Volume = 0; temp.Parent = workspace
        pcall(function() ContentProvider:PreloadAsync({temp}) end)
        task.wait(0.5)
        local tl = temp.TimeLength; temp:Destroy()
        soundHistory = soundHistory + 1
        local isWork = tl and tl > 0
        sndStatusLbl.Text = isWork and string.format('<font color="#44ff88">WORK — %.2fs</font>', tl) or '<font color="#ff5555">TIDAK WORK</font>'
        addHistoryRow(sndScroll, soundHistory, id, isWork, isWork and "WORK" or "TIDAK WORK")
    end)
end)

sndPlayBtn.MouseButton1Click:Connect(function()
