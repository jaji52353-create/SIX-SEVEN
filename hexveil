-- Activity detection
local function getPlayerFromPart(part)
    if not part then return nil end
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LP and p.Character and part:IsDescendantOf(p.Character) then return p end
    end
    return nil
end

local function clearActConns()
    for _, c in ipairs(actConns) do pcall(function() c:Disconnect() end) end
    actConns = {}
end

local function trackPlayer(p)
    if p == LP then return end
    local function onChar(c)
        local c1 = c.ChildAdded:Connect(function(child) if child:IsA("Tool") then addActLog(p.Name, "Equip: "..child.Name, "tool") end end)
        local c2 = c.ChildRemoved:Connect(function(child) if child:IsA("Tool") then addActLog(p.Name, "Unequip: "..child.Name, "tool") end end)
        table.insert(actConns, c1); table.insert(actConns, c2)
    end
    if p.Character then onChar(p.Character) end
    local conn = p.CharacterAdded:Connect(onChar)
    table.insert(actConns, conn)
end

for _, p in ipairs(Players:GetPlayers()) do trackPlayer(p) end
Players.PlayerAdded:Connect(function(p) addActLog(p.Name, "Bergabung ke server", "system"); trackPlayer(p) end)
Players.PlayerRemoving:Connect(function(p) addActLog(p.Name, "Meninggalkan server", "system") end)

local lastDmgSrc = nil; local lastDmgTime = 0

local function initActChar(char)
    clearActConns()
    lastDmgSrc = nil
    for _, p in ipairs(Players:GetPlayers()) do trackPlayer(p) end
    local hum = char:WaitForChild("Humanoid", 10); if not hum then return end
    char:WaitForChild("HumanoidRootPart", 10)
    local lastHP = hum.Health

    local function bindTouch(part)
        if not part:IsA("BasePart") then return end
        local c = part.Touched:Connect(function(hit)
            local attacker = getPlayerFromPart(hit)
            if attacker then lastDmgSrc = attacker.Name; lastDmgTime = tick() end
        end)
        table.insert(actConns, c)
    end
    for _, p in ipairs(char:GetDescendants()) do bindTouch(p) end
    local dc = char.DescendantAdded:Connect(function(d) bindTouch(d) end)
    table.insert(actConns, dc)

    local hc = hum.HealthChanged:Connect(function(newHp)
        local delta = newHp - lastHP
        if math.abs(delta) < 0.5 then lastHP = newHp return end
        local src = (lastDmgSrc and (tick() - lastDmgTime) < 1.5) and lastDmgSrc or "Sistem"
        if delta < 0 then
            addActLog(src, string.format("Damage %d HP", math.abs(math.floor(delta))), src == "Sistem" and "system" or "damage")
            lastDmgSrc = nil
        end
        lastHP = newHp
    end)
    table.insert(actConns, hc)

    local died = hum.Died:Connect(function()
        local src = (lastDmgSrc and (tick() - lastDmgTime) < 3) and lastDmgSrc or "Sistem"
        addActLog(src, "Karakter mati" .. (src ~= "Sistem" and " oleh " .. src or ""), "death")
        lastDmgSrc = nil
    end)
    table.insert(actConns, died)

    local ta = char.ChildAdded:Connect(function(child) if child:IsA("Tool") then addActLog("Kamu", "Equip: "..child.Name, "tool") end end)
    local tr = char.ChildRemoved:Connect(function(child) if child:IsA("Tool") then addActLog("Kamu", "Unequip: "..child.Name, "tool") end end)
    table.insert(actConns, ta); table.insert(actConns, tr)
end

