            tpBtn.Parent = row
            Instance.new("UICorner", tpBtn).CornerRadius = UDim.new(0, 6)

            local followBtn = Instance.new("TextButton", row)
            followBtn.Size = UDim2.new(0, 60, 0, 28)
            followBtn.Position = UDim2.new(1, -138, 0.5, -14)
            followBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 120)
            followBtn.Text = "Follow"
            followBtn.TextColor3 = Color3.fromRGB(255,255,255)
            followBtn.Font = Enum.Font.GothamBold
            followBtn.TextSize = 12
            followBtn.BorderSizePixel = 0
            followBtn.Parent = row
            Instance.new("UICorner", followBtn).CornerRadius = UDim.new(0, 6)

            tpBtn.MouseButton1Click:Connect(function()
                local targetChar = p.Character
                if targetChar then
                    local behind = getBehindCF(targetChar)
                    if behind then
                        local myChar = LocalPlayer.Character
                        if myChar then
                            local myRoot = myChar:FindFirstChild("HumanoidRootPart")
                            if myRoot then myRoot.CFrame = behind end
                        end
                    end
                end
                BGM:Play()
            end)

            followBtn.MouseButton1Click:Connect(function()
                if isFollowing and selectedPlayer == p then
                    stopFollow()
                    followBtn.Text = "Follow"
                    followBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 120)
                    selectedPlayer = nil
                else
                    stopFollow()
                    selectedPlayer = p
                    startFollow(p)
                    followBtn.Text = "Unfollow"
                    followBtn.BackgroundColor3 = Color3.fromRGB(200, 80, 80)
                end
                BGM:Play()
            end)

            table.insert(ptButtons, row)
        end
    end
end

