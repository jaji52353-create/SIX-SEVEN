end

saveLocBtn.MouseButton1Click:Connect(function()
    if #savedLocations >= 10 then
        addMonitorLog("⚠ Max 10 locations", Color3.fromRGB(255, 100, 100))
        return
    end
    local char = LocalPlayer.Character
